{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "meta_title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "page_title": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "categories": {
      "default": [
        "social media"
      ],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "button": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "link": {
          "type": "string"
        }
      },
      "required": [
        "label",
        "link"
      ],
      "additionalProperties": false
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ],
  "additionalProperties": false
}