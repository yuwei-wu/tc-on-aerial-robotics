---
import { markdownify } from "@/lib/utils/textConverter";

const { homepage_tab } = Astro.props;
const { title, description, tab_list } = homepage_tab;
---

<section class="py-10">
  <div class="w-full">
    <h2 class="lg:text-4xl" set:html={markdownify(title)} />
    <div class="mt-4 mb-8" set:html={markdownify(description)} />

    <div class="grid gap-6">
      {
        tab_list?.map((item: any) => (
          <article class="rounded-xl border border-border bg-white p-6">
            <h3 class="h5 mb-3">{item.title}</h3>
            <div set:html={markdownify(item.content)} />
          </article>
        ))
      }
    </div>
  </div>
</section>
