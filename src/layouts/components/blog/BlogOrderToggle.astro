---
import { withBasePath } from "@/lib/utils/basePath";

const { order, section = "blog" } = Astro.props;
const category = Astro.params.category;
const isNewest = order === "newest";
const isCategories = section === "categories";
const newestHref = isCategories
  ? category
    ? `/categories/${category}/`
    : "/categories/"
  : "/blog/";
const oldestHref = isCategories
  ? category
    ? `/categories/oldest/${category}/`
    : "/categories/oldest/"
  : "/blog/oldest/";
---

<div class="mb-6 flex flex-wrap items-center gap-3">
  <span class="text-sm font-medium text-text-dark">Sort by date:</span>
  {
    isNewest ? (
      <span class="btn btn-primary btn-sm inline-flex items-center justify-center no-underline">
        Newest first
      </span>
    ) : (
      <a
        class="btn btn-outline-primary btn-sm inline-flex items-center justify-center no-underline"
        href={withBasePath(newestHref)}
      >
        Newest first
      </a>
    )
  }
  {
    !isNewest ? (
      <span class="btn btn-primary btn-sm inline-flex items-center justify-center no-underline">
        Oldest first
      </span>
    ) : (
      <a
        class="btn btn-outline-primary btn-sm inline-flex items-center justify-center no-underline"
        href={withBasePath(oldestHref)}
      >
        Oldest first
      </a>
    )
  }
</div>
