---
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type Props = {
  members: CollectionEntry<"about">["data"]["members"];
};

const {
  members: { title, description, member_list },
} = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="row">
      <div class="mx-auto text-center lg:col-6">
        <h2 set:html={markdownify(title)} />
        <p class="mt-4" set:html={markdownify(description)} />
      </div>
    </div>
    <div class="row mt-12 justify-center">
      <div class="lg:col-10">
        <div class="row">
          {
            member_list.map((item) => (
              <div class="mb-6 flex flex-col px-6 text-center sm:col-6 lg:col-4 sm:items-center">
                <div class="member-avatar inline-flex justify-center">
                  <Image
                    height={220}
                    width={180}
                    class="h-56 w-44 object-cover"
                    src={item.image}
                    alt=""
                  />
                </div>
                <div class="mt-6 w-full flex-1 rounded-xl bg-white px-4 py-8 shadow-lg">
                  <h5 class="font-primary" set:html={markdownify(item.name)} />
                  <p class="mt-1.5" set:html={markdownify(item.field)} />
                  {
                    item.email && (
                      <p class="mt-3">
                        <a href={`mailto:${item.email}`} class="hover:text-primary">
                          {item.email}
                        </a>
                      </p>
                    )
                  }
                  {
                    item.webpage && (
                      <p class="mt-2">
                        <a
                          href={item.webpage}
                          class="hover:text-primary hover:underline"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          Webpage
                        </a>
                      </p>
                    )
                  }
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
