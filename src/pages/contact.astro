---
import PageHeader from "@/components/PageHeader.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";

const entry = (await getEntry(
  "contact",
  "-index"
)) as CollectionEntry<"contact">;
const { contact_form_action } = config.params;
const contact = entry.data;
const page_data = {
  ...contact,
  content: entry.body,
};
---

<Base
  title={contact.title}
  meta_title={contact.meta_title}
  description={contact.description}
  image={contact.image}
>
  <section class="page-hero pb-6 pt-16">
    <div class="container">
      <PageHeader page_data={page_data} />
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <div class="w-full">
        <form action={contact_form_action} method="POST">
          <div class="form-group mb-5">
            <label class="form-label" for="name">Your Name</label>
            <input
              class="form-control"
              type="text"
              id="name"
              name="name"
              placeholder="Your Name"
              required
            />
          </div>
          <div class="form-group mb-5">
            <label class="form-label" for="email">Your Email</label>
            <input
              class="form-control"
              type="email"
              id="email"
              name="email"
              placeholder="Your Email"
              required
            />
          </div>
          <div class="form-group mb-5">
            <label class="form-label" for="institution">
              Institution or Company
            </label>
            <input
              class="form-control"
              type="text"
              id="institution"
              name="institution"
              placeholder="Your Institution or Company"
              required
            />
          </div>
          <div class="form-group mb-5">
            <span class="form-label block">
              Interest Group or Interest Groups in Which You Are Interested
            </span>
            <div class="space-y-3 rounded-lg border border-border p-5">
              <label class="flex items-start gap-3 text-text-dark">
                <input
                  type="checkbox"
                  name="interest_groups"
                  value="IG1 - Unmanned aerial systems"
                  class="mt-1"
                />
                <span>IG1 - Unmanned aerial systems</span>
              </label>
              <label class="flex items-start gap-3 text-text-dark">
                <input
                  type="checkbox"
                  name="interest_groups"
                  value="IG2 - Aerial Robotic Systems physically interacting with the environment"
                  class="mt-1"
                />
                <span>
                  IG2 - Aerial Robotic Systems physically interacting with the
                  environment
                </span>
              </label>
              <label class="flex items-start gap-3 text-text-dark">
                <input
                  type="checkbox"
                  name="interest_groups"
                  value="IG3 - Perception based aerial robotics"
                  class="mt-1"
                />
                <span>IG3 - Perception based aerial robotics</span>
              </label>
            </div>
          </div>
          <div class="form-group mb-5">
            <label class="form-label" for="message">Additional Message</label>
            <textarea
              class="form-control"
              id="message"
              name="message"
              cols="30"
              rows="6"
              placeholder="Optional message"
            ></textarea>
          </div>
          <input
            class="btn btn-primary block w-full"
            type="submit"
            value="Join the IEEE TC List"
          />
        </form>
      </div>
    </div>
  </section>
</Base>
